# Supabase PostgreSQL — use the transaction pooler (port 6543) connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres

# Supabase project URL (for JWKS endpoint)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Only needed for seed script, not at runtime
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Server port
PORT=3000
